{
  "realm": "eodhp",
  "enabled": true,
  "clients": [
    {
      "clientId": "eodh-workspaces",
      "name": "EODH Workspace Services",
      "secret": "eodh-workspaces-secret",
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true
    }
  ],
  "groups": [
    {
      "name": "eodh-demos"
    },
    {
      "name": "samples-airbus-optical"
    },
    {
      "name": "samples-airbus-sar"
    },
    {
      "name": "samples-planet"
    }
  ],
  "users": [
    {
      "username": "dev-user",
      "enabled": true,
      "emailVerified": true,
      "email": "dev-user@example.com",
      "firstName": "Dev",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "devpass",
          "temporary": false
        }
      ],
      "groups": [
        "/eodh-demos",
        "/samples-airbus-optical",
        "/samples-airbus-sar",
        "/samples-planet"
      ]
    },
    {
      "username": "service-account-eodh-workspaces",
      "enabled": true,
      "serviceAccountClientId": "eodh-workspaces",
      "clientRoles": {
        "realm-management": [
          "view-users",
          "query-users",
          "view-groups",
          "query-groups",
          "manage-groups"
        ]
      }
    }
  ]
}
